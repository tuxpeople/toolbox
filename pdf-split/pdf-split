#!/usr/bin/env bash
# PDF-Split - Teilt ein PDF in einzelne Seiten auf
#
# Dieses Tool basiert auf einem Script von Matthew Hammond
# Original: https://gist.github.com/matthewshammond/23a217767ff93d733c8d11fff97b19f5
#
# Verwendung: pdf-split [OPTIONEN] <input.pdf> <output_directory>

set -euo pipefail

# Farben für Output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'  # No Color

# Globale Variablen
VERBOSE=false
DRY_RUN=false
PREFIX="page"
START_PAGE=""
END_PAGE=""

# Statistiken
STATS_TOTAL=0
STATS_SUCCESS=0
STATS_ERRORS=0

# Temporäres Verzeichnis für Cleanup
TEMP_DIR=""

# Log-Funktionen
log_info() {
    echo -e "${BLUE}[INFO]${NC} $1" >&2
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1" >&2
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1" >&2
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

log_verbose() {
    if [[ "$VERBOSE" == "true" ]]; then
        echo -e "${BLUE}[VERBOSE]${NC} $1" >&2
    fi
}

# Hilfe-Funktion
show_help() {
    cat << EOF
pdf-split - Teilt ein PDF in einzelne Seiten auf

VERWENDUNG:
    $0 [OPTIONEN] <input.pdf> <output_directory>

BESCHREIBUNG:
    Teilt eine PDF-Datei in einzelne Seiten auf. Jede Seite wird als separate
    PDF-Datei im Ausgabe-Verzeichnis gespeichert. Das Tool verwendet Python 3
    mit PyPDF2 in einem isolierten Virtual Environment.

OPTIONEN:
    -v, --verbose            Detaillierte Ausgabe
    -n, --dry-run            Nur anzeigen was gemacht würde
    -p, --prefix PREFIX      Präfix für Ausgabe-Dateien (Standard: "page")
    -s, --start-page NUM     Erste zu extrahierende Seite (Standard: 1)
    -e, --end-page NUM       Letzte zu extrahierende Seite (Standard: alle)
    -h, --help               Diese Hilfe anzeigen

VORAUSSETZUNGEN:
    - Python 3 mit venv-Modul muss installiert sein
    - PyPDF2 wird automatisch in einem temporären venv installiert

BEISPIELE:
    # Alle Seiten aufteilen
    $0 document.pdf output/

    # Mit eigenem Präfix
    $0 --prefix doc document.pdf output/

    # Nur Seiten 5-10 extrahieren
    $0 --start-page 5 --end-page 10 document.pdf output/

    # Dry-Run zum Testen
    $0 --dry-run document.pdf output/

    # Mit detaillierter Ausgabe
    $0 --verbose document.pdf output/

AUSGABE:
    Die einzelnen Seiten werden benannt als:
    - page_1.pdf, page_2.pdf, page_3.pdf, ...
    - Oder mit eigenem Präfix: doc_1.pdf, doc_2.pdf, ...

HINWEISE:
    - Das Ausgabe-Verzeichnis wird automatisch erstellt
    - Existierende Dateien werden überschrieben
    - Das Tool erstellt ein temporäres Virtual Environment
    - Alle temporären Dateien werden automatisch aufgeräumt

ORIGINALQUELLE:
    Basiert auf: https://gist.github.com/matthewshammond/23a217767ff93d733c8d11fff97b19f5
    Autor: Matthew Hammond
    Angepasst für toolbox nach CLAUDE.md Standards
EOF
}

# Abhängigkeiten prüfen
check_dependencies() {
    local missing_deps=()

    if ! command -v python3 &> /dev/null; then
        missing_deps+=("python3")
    fi

    if [[ ${#missing_deps[@]} -gt 0 ]]; then
        log_error "Fehlende Abhängigkeiten: ${missing_deps[*]}"
        log_info "Installation:"
        log_info "  macOS: brew install python3"
        log_info "  Linux: apt install python3 python3-venv oder yum install python3"
        return 1
    fi

    # Prüfe ob venv-Modul verfügbar ist
    if ! python3 -m venv --help &> /dev/null; then
        log_error "Python venv-Modul nicht verfügbar"
        log_info "Installation:"
        log_info "  Linux: apt install python3-venv oder yum install python3-venv"
        return 1
    fi

    return 0
}

# Argumente parsen
parse_arguments() {
    local positional_args=()

    while [[ $# -gt 0 ]]; do
        case $1 in
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            -n|--dry-run)
                DRY_RUN=true
                shift
                ;;
            -p|--prefix)
                if [[ -z "${2:-}" ]]; then
                    log_error "Option --prefix benötigt einen Wert"
                    return 1
                fi
                PREFIX="$2"
                shift 2
                ;;
            -s|--start-page)
                if [[ -z "${2:-}" ]]; then
                    log_error "Option --start-page benötigt einen Wert"
                    return 1
                fi
                START_PAGE="$2"
                shift 2
                ;;
            -e|--end-page)
                if [[ -z "${2:-}" ]]; then
                    log_error "Option --end-page benötigt einen Wert"
                    return 1
                fi
                END_PAGE="$2"
                shift 2
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            -*)
                log_error "Unbekannte Option: $1"
                show_help
                exit 1
                ;;
            *)
                positional_args+=("$1")
                shift
                ;;
        esac
    done

    # Positionale Argumente zurücksetzen
    set -- "${positional_args[@]}"

    # Prüfe auf genau 2 Argumente
    if [[ ${#positional_args[@]} -ne 2 ]]; then
        log_error "Genau 2 Argumente erforderlich: <input.pdf> <output_directory>"
        show_help
        return 1
    fi

    INPUT_PDF="${positional_args[0]}"
    OUTPUT_DIR="${positional_args[1]}"

    return 0
}

# Parameter validieren
validate_parameters() {
    # Prüfe Input-Datei
    if [[ ! -f "$INPUT_PDF" ]]; then
        log_error "Input-Datei nicht gefunden: $INPUT_PDF"
        return 1
    fi

    # Prüfe ob es eine PDF ist (einfacher Check)
    if [[ ! "$INPUT_PDF" =~ \.pdf$ ]]; then
        log_warn "Datei hat keine .pdf Endung: $INPUT_PDF"
    fi

    # Validiere Start/End-Page wenn gesetzt
    if [[ -n "$START_PAGE" ]]; then
        if ! [[ "$START_PAGE" =~ ^[0-9]+$ ]]; then
            log_error "Start-Seite muss eine Zahl sein: $START_PAGE"
            return 1
        fi
        if [[ "$START_PAGE" -lt 1 ]]; then
            log_error "Start-Seite muss >= 1 sein"
            return 1
        fi
    fi

    if [[ -n "$END_PAGE" ]]; then
        if ! [[ "$END_PAGE" =~ ^[0-9]+$ ]]; then
            log_error "End-Seite muss eine Zahl sein: $END_PAGE"
            return 1
        fi
        if [[ "$END_PAGE" -lt 1 ]]; then
            log_error "End-Seite muss >= 1 sein"
            return 1
        fi
    fi

    if [[ -n "$START_PAGE" ]] && [[ -n "$END_PAGE" ]]; then
        if [[ "$START_PAGE" -gt "$END_PAGE" ]]; then
            log_error "Start-Seite ($START_PAGE) muss <= End-Seite ($END_PAGE) sein"
            return 1
        fi
    fi

    # Validiere Präfix
    if [[ -z "$PREFIX" ]]; then
        log_error "Präfix darf nicht leer sein"
        return 1
    fi

    return 0
}

# Python-Script erstellen
create_python_script() {
    local script_path="$1"

    cat > "$script_path" << 'PYTHON_EOF'
#!/usr/bin/env python3

import os
import sys
from pathlib import Path

def split_pdf(input_pdf_path, output_dir, prefix, start_page, end_page, verbose, dry_run):
    """Teilt ein PDF in einzelne Seiten auf."""
    try:
        from PyPDF2 import PdfReader, PdfWriter
    except ImportError:
        print("ERROR: PyPDF2 konnte nicht importiert werden", file=sys.stderr)
        sys.exit(1)

    # Erstelle Output-Verzeichnis wenn nötig
    if not dry_run:
        if not os.path.exists(output_dir):
            os.makedirs(output_dir)
            if verbose:
                print(f"INFO: Verzeichnis erstellt: {output_dir}", file=sys.stderr)

    # Lese Input-PDF
    try:
        reader = PdfReader(input_pdf_path)
        total_pages = len(reader.pages)
    except Exception as e:
        print(f"ERROR: Fehler beim Lesen der PDF: {e}", file=sys.stderr)
        sys.exit(1)

    if verbose:
        print(f"INFO: PDF hat {total_pages} Seiten", file=sys.stderr)

    # Bestimme Start/End
    start = int(start_page) if start_page else 1
    end = int(end_page) if end_page else total_pages

    # Validiere Bereich
    if start > total_pages:
        print(f"ERROR: Start-Seite {start} > Gesamt-Seiten {total_pages}", file=sys.stderr)
        sys.exit(1)
    if end > total_pages:
        print(f"WARN: End-Seite {end} > Gesamt-Seiten {total_pages}, verwende {total_pages}", file=sys.stderr)
        end = total_pages

    # Teile jede Seite
    success_count = 0
    error_count = 0

    for page_num in range(start - 1, end):  # Python ist 0-basiert
        try:
            writer = PdfWriter()
            writer.add_page(reader.pages[page_num])

            output_filename = os.path.join(output_dir, f"{prefix}_{page_num + 1}.pdf")

            if dry_run:
                print(f"DRYRUN: Würde erstellen: {output_filename}", file=sys.stderr)
            else:
                with open(output_filename, "wb") as output_pdf:
                    writer.write(output_pdf)
                if verbose:
                    print(f"SUCCESS: Erstellt: {output_filename}", file=sys.stderr)

            success_count += 1

        except Exception as e:
            print(f"ERROR: Fehler bei Seite {page_num + 1}: {e}", file=sys.stderr)
            error_count += 1

    # Ausgabe Statistik
    print(f"STATS: {success_count} {error_count} {end - start + 1}")

def main():
    if len(sys.argv) != 8:
        print("ERROR: Falsche Anzahl Argumente", file=sys.stderr)
        sys.exit(1)

    input_pdf = sys.argv[1]
    output_dir = sys.argv[2]
    prefix = sys.argv[3]
    start_page = sys.argv[4]
    end_page = sys.argv[5]
    verbose = sys.argv[6] == "true"
    dry_run = sys.argv[7] == "true"

    split_pdf(input_pdf, output_dir, prefix, start_page, end_page, verbose, dry_run)

if __name__ == "__main__":
    main()
PYTHON_EOF

    chmod +x "$script_path"
}

# Cleanup-Funktion
cleanup() {
    if [[ -n "$TEMP_DIR" ]] && [[ -d "$TEMP_DIR" ]]; then
        log_verbose "Räume temporäre Dateien auf: $TEMP_DIR"
        rm -rf "$TEMP_DIR"
    fi
}

# PDF aufteilen
split_pdf() {
    local input="$1"
    local output="$2"

    # Erstelle temporäres Verzeichnis
    TEMP_DIR=$(mktemp -d)
    trap cleanup EXIT

    local script_path="$TEMP_DIR/split-pdf.py"
    local venv_dir="$TEMP_DIR/venv"

    log_verbose "Temporäres Verzeichnis: $TEMP_DIR"

    # Erstelle Python-Script
    log_verbose "Erstelle Python-Script"
    create_python_script "$script_path"

    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "DRY-RUN: Würde PDF aufteilen: $input -> $output"
        log_info "DRY-RUN: Präfix: $PREFIX"
        if [[ -n "$START_PAGE" ]]; then
            log_info "DRY-RUN: Start-Seite: $START_PAGE"
        fi
        if [[ -n "$END_PAGE" ]]; then
            log_info "DRY-RUN: End-Seite: $END_PAGE"
        fi

        # Führe Python-Script im Dry-Run aus
        log_info "Richte Python Virtual Environment ein..."
        python3 -m venv "$venv_dir" 2>&1 | while read -r line; do log_verbose "$line"; done

        log_info "Installiere PyPDF2..."
        "$venv_dir/bin/pip" install --quiet PyPDF2 2>&1 | while read -r line; do log_verbose "$line"; done

        log_info "Führe PDF-Split aus (Dry-Run)..."
        "$venv_dir/bin/python" "$script_path" "$input" "$output" "$PREFIX" "$START_PAGE" "$END_PAGE" "$VERBOSE" "true" 2>&1 | while IFS= read -r line; do
            if [[ "$line" =~ ^DRYRUN: ]]; then
                log_info "${line#DRYRUN: }"
            elif [[ "$line" =~ ^STATS: ]]; then
                read -r success errors total <<< "${line#STATS: }"
                STATS_SUCCESS=$success
                STATS_ERRORS=$errors
                STATS_TOTAL=$total
            fi
        done

        return 0
    fi

    # Normale Ausführung
    log_info "Richte Python Virtual Environment ein..."
    if ! python3 -m venv "$venv_dir" 2>&1 | while read -r line; do log_verbose "$line"; done; then
        log_error "Fehler beim Erstellen des Virtual Environment"
        return 1
    fi

    log_info "Installiere PyPDF2..."
    if ! "$venv_dir/bin/pip" install --quiet PyPDF2 2>&1 | while read -r line; do log_verbose "$line"; done; then
        log_error "Fehler bei der Installation von PyPDF2"
        return 1
    fi

    log_info "Teile PDF auf..."
    "$venv_dir/bin/python" "$script_path" "$input" "$output" "$PREFIX" "$START_PAGE" "$END_PAGE" "$VERBOSE" "false" 2>&1 | while IFS= read -r line; do
        if [[ "$line" =~ ^SUCCESS: ]]; then
            log_success "${line#SUCCESS: }"
        elif [[ "$line" =~ ^ERROR: ]]; then
            log_error "${line#ERROR: }"
        elif [[ "$line" =~ ^WARN: ]]; then
            log_warn "${line#WARN: }"
        elif [[ "$line" =~ ^INFO: ]]; then
            log_info "${line#INFO: }"
        elif [[ "$line" =~ ^STATS: ]]; then
            read -r success errors total <<< "${line#STATS: }"
            STATS_SUCCESS=$success
            STATS_ERRORS=$errors
            STATS_TOTAL=$total
        fi
    done

    return 0
}

# Hauptfunktion
main() {
    # 1. Abhängigkeiten prüfen
    if ! check_dependencies; then
        exit 1
    fi

    # 2. Parameter parsen
    if ! parse_arguments "$@"; then
        exit 1
    fi

    # 3. Parameter validieren
    if ! validate_parameters; then
        exit 1
    fi

    # 4. Informationen ausgeben
    log_info "PDF-Split wird gestartet"
    log_info "Input: $INPUT_PDF"
    log_info "Output: $OUTPUT_DIR"
    log_info "Präfix: $PREFIX"
    if [[ -n "$START_PAGE" ]]; then
        log_info "Start-Seite: $START_PAGE"
    fi
    if [[ -n "$END_PAGE" ]]; then
        log_info "End-Seite: $END_PAGE"
    fi

    # 5. PDF aufteilen
    if ! split_pdf "$INPUT_PDF" "$OUTPUT_DIR"; then
        log_error "Fehler beim Aufteilen der PDF"
        exit 1
    fi

    # 6. Statistiken ausgeben
    log_success "Fertig!"
    log_info "Statistik: $STATS_SUCCESS erfolgreich, $STATS_ERRORS Fehler, $STATS_TOTAL gesamt"
}

# Script-Ausführung
main "$@"

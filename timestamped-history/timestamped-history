#!/usr/bin/env bash

# Script: timestamped-history
# Zweck: Bash-History mit Timestamps anzeigen
# Verwendung: ./timestamped-history [OPTIONEN]

set -euo pipefail

# Farben für Output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'  # No Color

# Globale Variablen
VERBOSE=false
LINES=0
FILTER=""
DATE_FORMAT="%Y-%m-%d %H:%M:%S"
HISTORY_FILE="${HISTFILE:-$HOME/.bash_history}"

log_info() {
    echo -e "${BLUE}[INFO]${NC} $1" >&2
}

log_success() {
    echo -e "${GREEN}[SUCCESS]${NC} $1" >&2
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1" >&2
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $1" >&2
}

log_verbose() {
    if [[ "$VERBOSE" == "true" ]]; then
        echo -e "${BLUE}[VERBOSE]${NC} $1" >&2
    fi
}

show_help() {
    cat << EOF
bash-history - Bash-History mit Timestamps anzeigen

VERWENDUNG:
    $0 [OPTIONEN]

BESCHREIBUNG:
    Liest die Bash-History-Datei und zeigt Befehle mit Timestamps an.
    Befehle ohne gespeicherten Timestamp werden mit "?" markiert.
    Unterstützt Filterung, Anzahl-Begrenzung und anpassbares Datumsformat.

OPTIONEN:
    -n, --lines N            Nur die letzten N Einträge anzeigen
    -f, --filter MUSTER      Nur Einträge anzeigen, die MUSTER enthalten
    -d, --date-format FMT    Datumsformat (Standard: "%Y-%m-%d %H:%M:%S")
    -F, --file DATEI         History-Datei (Standard: \$HISTFILE oder ~/.bash_history)
    -v, --verbose            Detaillierte Ausgabe
    -h, --help               Diese Hilfe anzeigen

UMGEBUNGSVARIABLEN:
    HISTFILE                 Pfad zur Bash-History-Datei (Standard: ~/.bash_history)

BEISPIELE:
    $0                           # Alle History-Einträge mit Timestamps
    $0 -n 50                     # Letzte 50 Einträge anzeigen
    $0 -f "git"                  # Nur git-Befehle anzeigen
    $0 -n 100 -f "kubectl"       # Letzte 100 kubectl-Befehle
    $0 -d "%d.%m.%Y %H:%M"      # Deutsches Datumsformat
    $0 -F ~/.zsh_history         # Andere History-Datei verwenden

VORAUSSETZUNGEN:
    - awk mit strftime-Unterstützung (auf macOS und Linux standardmässig verfügbar)
    - Bash-History-Datei mit Timestamp-Format

HINWEISE:
    - Timestamps erscheinen nur, wenn HISTTIMEFORMAT in der Shell gesetzt war/ist
    - Die aktuelle Session-History wird möglicherweise erst nach "history -a" gespeichert
    - Um Timestamps dauerhaft zu aktivieren, folgendes in ~/.bashrc hinzufügen:
      export HISTTIMEFORMAT="%F %T "
EOF
}

check_dependencies() {
    local missing_deps=()

    if ! command -v awk &> /dev/null; then
        missing_deps+=("awk")
    fi

    if [[ ${#missing_deps[@]} -gt 0 ]]; then
        log_error "Fehlende Abhängigkeiten: ${missing_deps[*]}"
        log_info "Installation:"
        log_info "  macOS: brew install gawk"
        log_info "  Linux: apt install gawk oder yum install gawk"
        return 1
    fi

    return 0
}

parse_arguments() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            -n|--lines)
                LINES="$2"
                shift 2
                ;;
            -f|--filter)
                FILTER="$2"
                shift 2
                ;;
            -d|--date-format)
                DATE_FORMAT="$2"
                shift 2
                ;;
            -F|--file)
                HISTORY_FILE="$2"
                shift 2
                ;;
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            -h|--help)
                show_help
                exit 0
                ;;
            *)
                log_error "Unbekannte Option: $1"
                show_help
                exit 1
                ;;
        esac
    done
}

validate_parameters() {
    if [[ ! -f "$HISTORY_FILE" ]]; then
        log_error "History-Datei nicht gefunden: $HISTORY_FILE"
        return 1
    fi

    if [[ ! -r "$HISTORY_FILE" ]]; then
        log_error "History-Datei nicht lesbar: $HISTORY_FILE"
        return 1
    fi

    if [[ "$LINES" != "0" && ! "$LINES" =~ ^[0-9]+$ ]]; then
        log_error "Ungültige Zeilenanzahl: $LINES"
        return 1
    fi

    return 0
}

display_history() {
    local file="$1"

    log_verbose "Lese History-Datei: $file"

    awk -v filter="$FILTER" -v max_lines="$LINES" -v date_fmt="$DATE_FORMAT" '
    BEGIN {
        count = 0
        current_ts = ""
    }
    /^#[0-9]+$/ {
        current_ts = substr($0, 2)
        next
    }
    {
        cmd = $0
        if (filter == "" || index(cmd, filter) > 0) {
            count++
            timestamps[count] = current_ts
            cmds[count] = cmd
        }
        current_ts = ""
    }
    END {
        start = 1
        if (max_lines > 0 && count > max_lines) {
            start = count - max_lines + 1
        }
        display_count = count - start + 1
        num_width = length(display_count)
        if (num_width < 1) num_width = 1
        num = 1
        for (i = start; i <= count; i++) {
            if (timestamps[i] != "") {
                formatted_ts = strftime(date_fmt, timestamps[i])
            } else {
                formatted_ts = "?"
            }
            printf "%*d  %s  %s\n", num_width, num, formatted_ts, cmds[i]
            num++
        }
    }
    ' "$file"
}

main() {
    if ! check_dependencies; then
        exit 1
    fi

    parse_arguments "$@"

    if ! validate_parameters; then
        show_help
        exit 1
    fi

    log_verbose "History-Datei: $HISTORY_FILE"
    log_verbose "Datumsformat: $DATE_FORMAT"
    [[ -n "$FILTER" ]] && log_verbose "Filter: $FILTER"
    [[ "$LINES" -gt 0 ]] && log_verbose "Max. Einträge: $LINES"

    display_history "$HISTORY_FILE"
}

main "$@"
